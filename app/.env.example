#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

# development | production
CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://example.com/'
app.forceGlobalSecureRequests = true
app.CSPEnabled = false

# Trusted proxy (Docker / nginx). Uncomment if behind reverse proxy.
# app.proxyIPs = '172.16.0.0/12'

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = mysql
database.default.database = simple_site2
database.default.username = cms_user
database.default.password = CHANGE_ME_DB_PASSWORD
database.default.DBDriver = MySQLi
database.default.port = 3306
database.default.DBDebug = false

#--------------------------------------------------------------------
# ENCRYPTION (generate: php spark key:generate)
#--------------------------------------------------------------------

# encryption.key = hex2bin:...

#--------------------------------------------------------------------
# COOKIE / SESSION (HTTPS)
#--------------------------------------------------------------------

cookie.secure = true
cookie.httponly = true
cookie.samesite = Lax

session.expiration = 7200

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

logger.threshold = 4

#--------------------------------------------------------------------
# INITIAL ADMIN (only for: php spark db:seed SuperAdministratorSeeder)
#--------------------------------------------------------------------

# ADMIN_INITIAL_PASSWORD = strong-password-here
# ADMIN_EMAIL = admin@example.com
