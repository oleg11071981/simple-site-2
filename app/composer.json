{
    "name": "codeigniter4/appstarter",
    "description": "CodeIgniter4 project starter",
    "license": "MIT",
    "require": {
        "php": "^7.4",
        "codeigniter4/framework": "4.4.8",
      "ext-mbstring": "*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^9.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "support": {
        "source": "https://github.com/codeigniter4/CodeIgniter4",
        "forum": "http://forum.codeigniter.com/",
        "issues": "https://github.com/codeigniter4/CodeIgniter4/issues",
        "slack": "https://codeigniterchat.slack.com"
    },
    "config": {
        "audit": {
            "ignore": ["PKSA-7ybs-j1bv-y5mc", "PKSA-qbjf-dc24-wrff"]
        }
    }
}
